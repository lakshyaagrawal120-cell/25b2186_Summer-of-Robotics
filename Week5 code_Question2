import rclpy
from rclpy.node import Node
from trajectory_msgs.msg import JointTrajectory, JointTrajectoryPoint
from builtin_interfaces.msg import Duration

class DirectArmController(Node):
    def __init__(self):
        super().__init__('direct_arm_controller')
        
        self.publisher_ = self.create_publisher(
            JointTrajectory, 
            '/arm_controller/joint_trajectory', 
            10
        )
        
        self.timer = self.create_timer(0.5, self.move_arm)
        self.get_logger().info("Node started. Waiting for the trajectory controller to connect...")

    def move_arm(self):
        if self.publisher_.get_subscription_count() == 0:
            return
            
        self.get_logger().info("Connection established! Dispatching trajectory to hardware...")
        
        msg = JointTrajectory()
        msg.joint_names = [
            'shoulder_pan_joint',
            'shoulder_lift_joint',
            'elbow_joint',
            'wrist_joint',
            'left_finger_joint',
            'right_finger_joint'
        ]
        
        point = JointTrajectoryPoint()
        point.positions = [0.5, 0.5, 0.5, 0.5, 0.02, 0.02]
        point.time_from_start = Duration(sec=3, nanosec=0)
        
        msg.points.append(point)
        
        self.publisher_.publish(msg)
        self.get_logger().info("Trajectory published. The arm should be moving now!")
        
        self.timer.cancel()

def main(args=None):
    rclpy.init(args=args)
    node = DirectArmController()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()
