import rclpy
from rclpy.node import Node
from trajectory_msgs.msg import JointTrajectory, JointTrajectoryPoint
from builtin_interfaces.msg import Duration
import math

class DirectArmController(Node):
    def __init__(self):
        super().__init__('direct_arm_controller')
        
        # ALERT: Verify your exact trajectory controller topic name via 'ros2 topic list'
        # Common names include '/joint_trajectory_controller/joint_trajectory' or '/arm_controller/joint_trajectory'
        self.publisher_ = self.create_publisher(
            JointTrajectory, 
            '/arm_controller/joint_trajectory', 
            10
        )
        
        # Timer to allow system initialization before firing commands
        self.timer = self.create_timer(2.0, self.move_arm)
        self.get_logger().info("Direct Controller initialized. Standing by for command dispatch...")

    def move_arm(self):
        self.timer.cancel() # Execute only once
        
        msg = JointTrajectory()
        
        # ALERT: Check your URDF files for precise naming of your 4 joints!
        msg.joint_names = ['joint_1', 'joint_2', 'joint_3', 'joint_4']
        
        # Setup the target waypoint point
        point = JointTrajectoryPoint()
        
        # Here, implement your explicit analytical formulas from Part A, or hardcode verification values:
        # Let's say target analytical angles evaluated to:
        theta1 = math.radians(45.0)  # Base
        theta2 = math.radians(30.0)  # Shoulder
        theta3 = math.radians(60.0)  # Elbow
        theta4 = math.radians(-15.0) # Wrist
        
        point.positions = [theta1, theta2, theta3, theta4]
        
        # Give the gazebo physics engine ample time (e.g., 4 seconds) to complete motion smoothly
        point.time_from_start = Duration(sec=4, nanosec=0)
        
        msg.points.append(point)
        msg.header.stamp = self.get_clock().now().to_msg()
        
        self.get_logger().info("Publishing computed IK Joint Trajectory values directly to hardware...")
        self.publisher_.publish(msg)
        self.get_logger().info("Trajectory published. Check Gazebo simulation space for motion.")

def main(args=None):
    rclpy.init(args=args)
    node = DirectArmController()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()
