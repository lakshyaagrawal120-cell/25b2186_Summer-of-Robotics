<?xml version="1.0" ?>
<!--
  house.world — Residential floor plan for indoor navigation.
  All primitives: loads instantly, no external model downloads required.

  Floor plan (16 m × 12 m, centred at origin):
  ┌──────────────────────────────────┐
  │  Living room   │  Kitchen/Dining │
  │  (west, large) │  (NE)           │
  │                ├─────────────────│
  │    Hallway     │  Bedroom 1 (SE) │
  ├────────────────┤                 │
  │  Bedroom 2(SW) │  Bathroom (E)   │
  └──────────────────────────────────┘

  Coordinates (interior face of outer walls):
    x: -7.9 to +7.9,   y: -5.9 to +5.9

  Room approximate bounds:
    Living room  : x=-7.9 to +0, y=-0.5 to +5.9
    Kitchen      : x=+0   to +7.9, y=+1.5 to +5.9
    Hallway      : x=-7.9 to +7.9, y=-0.5 to +1.5  (connects all rooms)
    Bedroom 1    : x=+2   to +7.9, y=-5.9 to -0.5
    Bedroom 2    : x=-7.9 to -1, y=-5.9 to -0.5
    Bathroom     : x=-1   to +2, y=-5.9 to -0.5

  Robot spawn area:  living room, x=-6 to -2, y=1.5 to 4.5

  Launch:
    ros2 launch diff_drive_robot multi_robot.launch.py world:=house
    ros2 launch diff_drive_robot slam_nav.launch.py world_name:=house explore:=true
-->
<sdf version='1.8'>
  <world name='house'>

    <physics name='1ms' type='ignored'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="ignition-gazebo-contact-system"
            name="ignition::gazebo::systems::Contact"/>

    <light name='sun' type='directional'>
      <pose>0 0 12 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>-0.3 0.1 -0.9</direction>
      <diffuse>1.0 0.97 0.90 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
    </light>
    <light name='ceiling_living' type='point'>
      <pose>-4 3 3 0 0 0</pose>
      <diffuse>0.9 0.85 0.75 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>12</range><linear>0.08</linear></attenuation>
    </light>
    <light name='ceiling_kitchen' type='point'>
      <pose>4 4 3 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>10</range><linear>0.1</linear></attenuation>
    </light>
    <light name='ceiling_hall' type='point'>
      <pose>0 0.5 3 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>12</range><linear>0.1</linear></attenuation>
    </light>

    <!-- ── Ground / floor ───────────────────────────────────────────────── -->
    <model name='ground_plane'>
      <static>true</static>
      <link name='link'>
        <collision name='c'>
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name='v'>
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.88 0.82 0.72 1</ambient><diffuse>0.88 0.82 0.72 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ── Room floor pads (h=0.004, coloured per room) ─────────────────── -->
    <!-- Living room: warm cream -->
    <model name='floor_living'>
      <static>true</static><pose>-4 2.7 0.003 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>7.8 11 0.004</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>7.8 11 0.004</size></box></geometry>
          <material><ambient>0.95 0.90 0.78 0.8</ambient><diffuse>0.95 0.90 0.78 0.8</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Kitchen: light tile -->
    <model name='floor_kitchen'>
      <static>true</static><pose>4 3.7 0.003 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>7.8 4.4 0.004</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>7.8 4.4 0.004</size></box></geometry>
          <material><ambient>0.92 0.92 0.88 0.8</ambient><diffuse>0.92 0.92 0.88 0.8</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Bedroom 1: blue-grey carpet -->
    <model name='floor_bed1'>
      <static>true</static><pose>5 -3.2 0.003 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>5.8 5.2 0.004</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>5.8 5.2 0.004</size></box></geometry>
          <material><ambient>0.72 0.78 0.88 0.8</ambient><diffuse>0.72 0.78 0.88 0.8</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Bedroom 2: green carpet -->
    <model name='floor_bed2'>
      <static>true</static><pose>-4.5 -3.2 0.003 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>6.8 5.2 0.004</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>6.8 5.2 0.004</size></box></geometry>
          <material><ambient>0.75 0.88 0.78 0.8</ambient><diffuse>0.75 0.88 0.78 0.8</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Bathroom: grey tile -->
    <model name='floor_bath'>
      <static>true</static><pose>0.5 -3.2 0.003 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>3 5.2 0.004</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>3 5.2 0.004</size></box></geometry>
          <material><ambient>0.78 0.78 0.78 0.8</ambient><diffuse>0.78 0.78 0.78 0.8</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ── Outer walls (16 m × 12 m, 2.5 m tall, h=0.2 m thick) ─────────── -->
    <!-- North wall -->
    <model name='wall_n'><static>true</static><pose>0  6 1.25 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>16.4 0.2 2.5</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>16.4 0.2 2.5</size></box></geometry>
        <material><ambient>0.88 0.82 0.76 1</ambient><diffuse>0.88 0.82 0.76 1</diffuse></material>
      </visual></link></model>
    <!-- South wall -->
    <model name='wall_s'><static>true</static><pose>0 -6 1.25 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>16.4 0.2 2.5</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>16.4 0.2 2.5</size></box></geometry>
        <material><ambient>0.88 0.82 0.76 1</ambient><diffuse>0.88 0.82 0.76 1</diffuse></material>
      </visual></link></model>
    <!-- East wall -->
    <model name='wall_e'><static>true</static><pose>8  0 1.25 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>0.2 12 2.5</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>0.2 12 2.5</size></box></geometry>
        <material><ambient>0.88 0.82 0.76 1</ambient><diffuse>0.88 0.82 0.76 1</diffuse></material>
      </visual></link></model>
    <!-- West wall -->
    <model name='wall_w'><static>true</static><pose>-8  0 1.25 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>0.2 12 2.5</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>0.2 12 2.5</size></box></geometry>
        <material><ambient>0.88 0.82 0.76 1</ambient><diffuse>0.88 0.82 0.76 1</diffuse></material>
      </visual></link></model>

    <!-- ── Interior walls ────────────────────────────────────────────────── -->
    <!--
      Wall layout (thickness 0.15 m, height 2.4 m):

      N-S wall dividing living room / kitchen-dining:
        x=0, y=1.5 to 6  (no door)

      E-W hallway walls:
        y=1.5, x=-8 to +8  (with 1 m door gaps: living@x=-4, bed2@x=-4, bed1@x=4, bath@x=0.5)
        Actually: two wall segments at y=1.5 with gaps:
          west segment: x=-8 to -6  (before living room door)
          after living door gap (-6 to -5) …  hmm

      Let me simplify to clear wall segments with logical doorways.

      Walls:
      1. N-S divider (living | kitchen): x=0, y=1.5 to 6, full height — no door
      2. E-W hallway wall (y=-0.5):
           west half (x=-8 to -3.5): solid  → living room south edge
           gap (x=-3.5 to -2): doorway into living room
           east half (x=-2 to 8): solid
           gap (x=2 to 3.5): doorway into kitchen (optional, kitchen open to hall)
      3. E-W lower wall (y=-0.5, south face of hall):
           Actually let me put living room floor as y=-0.5 to 6
           and hallway at y=-0.5 to -1.5
           and bedrooms below y=-1.5

      Simpler interpretation:

      HALLWAY: y=0 to 1.5 (1.5m wide, full x width)

      Interior wall A — hallway south (y=0):
        x=-8 to -3: solid (bedroom2 north)
        gap x=-3 to -1.5: door to bedroom2
        x=-1.5 to +0: solid (bathroom north)
        gap x=0 to +1.5: door to bathroom
        x=+1.5 to +8: solid (bedroom1 north)

      Interior wall B — hallway north / living-kitchen divide (y=1.5):
        x=-8 to -5: solid (living room south)
        gap x=-5 to -3.5: door to living room from hall
        x=-3.5 to 0: solid (living room south)
        x=0 to +5: solid (kitchen south)
        gap x=+5 to +6.5: door to kitchen from hall
        x=+6.5 to +8: solid (kitchen south)

      Interior wall C — living/kitchen N-S (x=0):
        y=1.5 to 6: solid (no door between living and kitchen)
    -->

    <!-- Wall A — south side of hallway (y=0), bedroom/bathroom north walls -->
    <!-- Segment A1: x=-8 to -3 (bedroom2 north) -->
    <model name='wall_A1'><static>true</static><pose>-5.5 0 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>5 0.15 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>5 0.15 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>
    <!-- Gap A: x=-3 to -1.5 (door to bedroom2) -->
    <!-- Segment A2: x=-1.5 to +0.5 (bathroom north) -->
    <model name='wall_A2'><static>true</static><pose>-0.5 0 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>2 0.15 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>2 0.15 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>
    <!-- Gap A3: x=0.5 to +2 (door to bathroom) -->
    <!-- Segment A4: x=+2 to +8 (bedroom1 north) -->
    <model name='wall_A4'><static>true</static><pose>5 0 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>6 0.15 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>6 0.15 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>

    <!-- Wall B — north side of hallway (y=1.5), living room / kitchen south walls -->
    <!-- Segment B1: x=-8 to -5.5 (living room south, west) -->
    <model name='wall_B1'><static>true</static><pose>-6.75 1.5 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>2.5 0.15 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>2.5 0.15 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>
    <!-- Gap B: x=-5.5 to -4 (door to living room) -->
    <!-- Segment B2: x=-4 to 0 (living room south, east) -->
    <model name='wall_B2'><static>true</static><pose>-2 1.5 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>4 0.15 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>4 0.15 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>
    <!-- Segment B3: x=0 to +5 (kitchen south, west) -->
    <model name='wall_B3'><static>true</static><pose>2.5 1.5 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>5 0.15 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>5 0.15 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>
    <!-- Gap B4: x=+5 to +6.5 (door to kitchen) -->
    <!-- Segment B5: x=+6.5 to +8 (kitchen south, east) -->
    <model name='wall_B5'><static>true</static><pose>7.25 1.5 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>1.5 0.15 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>1.5 0.15 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>

    <!-- Wall C — living/kitchen N-S divider (x=0, y=1.5 to 6) -->
    <model name='wall_C'><static>true</static><pose>0 3.75 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>0.15 4.5 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>0.15 4.5 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>

    <!-- Wall D — bedroom2 / bathroom divider (x=-1, y=-6 to 0) -->
    <model name='wall_D'><static>true</static><pose>-1 -3 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>0.15 6 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>0.15 6 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>

    <!-- Wall E — bathroom / bedroom1 divider (x=+2, y=-6 to 0) -->
    <model name='wall_E'><static>true</static><pose>2 -3 1.2 0 0 0</pose><link name='link'>
      <collision name='c'><geometry><box><size>0.15 6 2.4</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>0.15 6 2.4</size></box></geometry>
        <material><ambient>0.85 0.78 0.70 1</ambient><diffuse>0.85 0.78 0.70 1</diffuse></material>
      </visual></link></model>

    <!-- ── Furniture (static obstacles) ─────────────────────────────────── -->

    <!-- Sofa in living room -->
    <model name='sofa'>
      <static>true</static><pose>-5.5 4.5 0.4 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>2.2 0.8 0.8</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>2.2 0.8 0.8</size></box></geometry>
          <material><ambient>0.45 0.38 0.55 1</ambient><diffuse>0.45 0.38 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Coffee table -->
    <model name='coffee_table'>
      <static>true</static><pose>-5.5 3.2 0.22 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>1.0 0.55 0.44</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>1.0 0.55 0.44</size></box></geometry>
          <material><ambient>0.55 0.40 0.28 1</ambient><diffuse>0.55 0.40 0.28 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- TV stand (against west wall) -->
    <model name='tv_stand'>
      <static>true</static><pose>-7.4 1.8 0.3 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>0.4 1.5 0.6</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>0.4 1.5 0.6</size></box></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Kitchen counter (against north wall) -->
    <model name='counter_n'>
      <static>true</static><pose>4 5.4 0.45 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>7.5 0.6 0.9</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>7.5 0.6 0.9</size></box></geometry>
          <material><ambient>0.88 0.82 0.78 1</ambient><diffuse>0.88 0.82 0.78 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Kitchen island -->
    <model name='island'>
      <static>true</static><pose>4 3.0 0.45 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>2.2 0.9 0.9</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>2.2 0.9 0.9</size></box></geometry>
          <material><ambient>0.92 0.88 0.82 1</ambient><diffuse>0.92 0.88 0.82 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Bed in bedroom 1 (SE) -->
    <model name='bed_1'>
      <static>true</static><pose>5.5 -4.2 0.3 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>2.0 1.6 0.6</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>2.0 1.6 0.6</size></box></geometry>
          <material><ambient>0.72 0.78 0.88 1</ambient><diffuse>0.72 0.78 0.88 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Nightstand bed1 -->
    <model name='ns_1'>
      <static>true</static><pose>7.0 -3.5 0.25 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>0.5 0.5 0.5</size></box></geometry>
          <material><ambient>0.55 0.45 0.35 1</ambient><diffuse>0.55 0.45 0.35 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Bed in bedroom 2 (SW) -->
    <model name='bed_2'>
      <static>true</static><pose>-4.8 -4.2 0.3 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>2.0 1.6 0.6</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>2.0 1.6 0.6</size></box></geometry>
          <material><ambient>0.75 0.88 0.78 1</ambient><diffuse>0.75 0.88 0.78 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Wardrobe bed2 (against west wall) -->
    <model name='wardrobe'>
      <static>true</static><pose>-7.4 -3.5 0.7 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>0.6 2.0 1.4</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>0.6 2.0 1.4</size></box></geometry>
          <material><ambient>0.65 0.50 0.38 1</ambient><diffuse>0.65 0.50 0.38 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Bathroom fixtures -->
    <!-- Bathtub (against east wall) -->
    <model name='bathtub'>
      <static>true</static><pose>0.5 -4.8 0.2 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>1.6 0.7 0.4</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>1.6 0.7 0.4</size></box></geometry>
          <material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Toilet -->
    <model name='toilet'>
      <static>true</static><pose>0.5 -1.2 0.2 0 0 0</pose>
      <link name='link'>
        <collision name='c'><geometry><box><size>0.5 0.5 0.4</size></box></geometry></collision>
        <visual name='v'><geometry><box><size>0.5 0.5 0.4</size></box></geometry>
          <material><ambient>0.90 0.90 0.90 1</ambient><diffuse>0.90 0.90 0.90 1</diffuse></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
